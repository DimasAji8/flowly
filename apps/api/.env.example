# Server
PORT=3333
NODE_ENV=development

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:4000,http://localhost:3000

# Database — ganti PASSWORD dengan password Postgres lokal user "dimas"
DATABASE_URL="postgresql://dimas:PASSWORD@localhost:5432/flowly_dev?schema=public"

# JWT (isi dengan secret acak panjang saat develop / production)
JWT_SECRET=replace-me-with-strong-secret
JWT_REFRESH_SECRET=replace-me-with-another-strong-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Service (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxxx
EMAIL_FROM=noreply@temankas.com
APP_NAME=Teman Kas
APP_URL=http://localhost:4000
