{
  "name": "flowly",
  "version": "0.1.0",
  "private": true,
  "description": "Flowly - mobile-first cashflow app (monorepo)",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently -n WEB,API -c blue,green \"npm run dev -w web\" \"npm run start:dev -w api\"",
    "dev:web": "npm run dev -w web -- --port 3000",
    "dev:api": "npm run start:dev -w api",
    "build": "npm run build -w web && npm run build -w api",
    "start:web": "npm run start -w web",
    "start:api": "npm run start:prod -w api",
    "lint": "npm run lint --workspaces --if-present",
    "db:deploy": "npm run prisma:deploy -w api",
    "db:migrate": "npm run prisma:migrate -w api",
    "db:studio": "npm run prisma:studio -w api",
    "db:generate": "npm run prisma:generate -w api"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
